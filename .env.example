# 应用配置
NUXT_APP_NAME=ECshopX
NUXT_APP_TITLE=ECshopX - 新一代电商解决方案
NUXT_APP_DESCRIPTION=ECshopX 是一个基于 Nuxt 4 的现代电商解决方案
# 业务模式：b2c（默认）或 bbc（BBC 模式，展示店铺信息等 BBC 特有功能）
NUXT_PUBLIC_BUSINESS_MODE=b2c

# API 配置
NUXT_PUBLIC_API_BASE=https:/{host_name}/api/h5app
NUXT_PUBLIC_API_TIMEOUT=30000

# SaaS 配置
NUXT_PUBLIC_SAAS=false
NUXT_PUBLIC_COMPANY_ID=1

# 上传配置
NUXT_PUBLIC_UPLOAD_URL=/api/upload
NUXT_PUBLIC_UPLOAD_MAX_SIZE=5242880 # 5MB
NUXT_PUBLIC_UPLOAD_ACCEPT=image/*

# 缓存配置
NUXT_PUBLIC_CACHE_TTL=3600 # 1小时

# 装修预览通讯配置：允许这些管理后台 origin 通过 iframe postMessage 控制预览, host_name 为管理后台域名
NUXT_PUBLIC_DECORATION_ADMIN_ORIGINS=http://localhost:8080,https://{host_name}


# 注意：
# 1. NUXT_PUBLIC_ 前缀的变量在客户端和服务端都可以访问
# 2. 没有 NUXT_PUBLIC_ 前缀的变量只能在服务端访问
# 3. 生产环境请修改敏感信息（如 NUXT_COOKIE_SECRET）
# 4. 本地开发请复制此文件为 .env 并根据需要修改
